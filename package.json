{
  "name": "pm-kit",
  "version": "0.1.0",
  "description": "pm-kit CLI for installing product-management command assets into Claude Code and Codex projects",
  "license": "MIT",
  "type": "module",
  "bin": {
    "pmkit": "dist/cli/main.js"
  },
  "files": [
    "dist",
    "assets",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "prepare": "npm run build",
    "cli": "tsx src/cli/main.ts"
  },
  "keywords": [
    "cli",
    "codex",
    "claude-code",
    "product-management",
    "spec-kit"
  ],
  "dependencies": {
    "commander": "^14.0.0",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  }
}
